{
  "cluster": "prod-ocp-cluster-01",
  "region": "us-east-1",
  "node_type": "m5.2xlarge",
  "node_vcpu": 8,
  "node_ram_gb": 32,
  "node_cost_per_hour": 0.384,
  "sample_window_days": 14,
  "workloads": [
    {
      "namespace": "payments",
      "deployment": "payment-service",
      "replicas": 4,
