      "requests": { "cpu_millicores": 2000, "memory_mb": 4096 },
      "limits":   { "cpu_millicores": 2000, "memory_mb": 4096 },
      "observed": {
        "cpu_p50_millicores": 180,
        "cpu_p95_millicores": 420,
        "cpu_p99_millicores": 680,
        "cpu_max_millicores": 1850,
        "memory_p50_mb": 1240,
        "memory_p95_mb": 1580,
        "memory_p99_mb": 1820,
        "memory_max_mb": 2100,
        "gc_pause_p99_ms": 180,
        "heap_max_mb": 3072
      },
      "notes": "CPU max spike is GC threads during full GC — not real application load"
    },
    {
      "namespace": "payments",
      "deployment": "fraud-detection",
